---
import Layout from "../../../layouts/Layout.astro";
import AppointmentList from "../../../components/appointments/AppointmentList";
import WorkScheduleManager from "../../../components/work-schedule/WorkScheduleManager";
import DayScheduleGrid from "../../../components/appointments/DayScheduleGrid";
import ManualAppointmentTrigger from "../../../components/appointments/ManualAppointmentTrigger";
---

<Layout
    title="Dashboard de Proveedor"
    description="Gestiona tus citas y disponibilidad"
>
    <main class="py-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Header -->
            <div class="md:flex md:items-center md:justify-between">
                <div class="flex-1 min-w-0">
                    <h1
                        class="text-2xl font-bold text-pm-text sm:text-3xl"
                        id="dashboard-title"
                    >
                        Dashboard
                    </h1>
                    <div class="mt-1 flex items-center text-sm text-pm-muted">
                        <svg
                            class="flex-shrink-0 mr-1.5 h-4 w-4 text-pm-dim"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                            ></path>
                        </svg>
                        <span id="provider-info">Proveedor de Servicios</span>
                    </div>
                </div>
                <div class="mt-4 flex md:mt-0 md:ml-4 space-x-3">
                    <button
                        onclick="location.reload()"
                        class="inline-flex items-center px-4 py-2 border border-pm-border rounded-lg text-sm font-medium text-pm-muted hover:text-pm-text hover:border-pm-gold transition-colors"
                    >
                        Actualizar
                    </button>
                    <a
                        id="btn-team"
                        href="/provider/team"
                        class="hidden inline-flex items-center px-4 py-2 border border-pm-border rounded-lg text-sm font-medium text-pm-muted hover:text-pm-text hover:border-pm-gold transition-colors"
                    >
                        Equipo
                    </a>
                    <ManualAppointmentTrigger client:load />
                    <a
                        id="btn-schedule"
                        href="/provider/schedule"
                        class="hidden inline-flex items-center px-4 py-2 text-sm font-semibold rounded-lg text-pm-bg bg-pm-gold hover:bg-pm-gold-light transition-colors"
                    >
                        Configurar Horarios
                    </a>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-4">
                <button
                    onclick="filterAppointments('ALL')"
                    class="bg-pm-surface border border-pm-border rounded-xl p-5 w-full text-left hover:border-pm-gold transition-colors group cursor-pointer"
                >
                    <div class="flex items-center justify-between">
                        <div>
                            <p
                                class="text-xs font-medium text-pm-dim uppercase tracking-wider"
                            >
                                Total Citas
                            </p>
                            <p
                                class="text-2xl font-bold text-pm-text mt-1"
                                id="total-appointments"
                            >
                                —
                            </p>
                        </div>
                        <div
                            class="h-10 w-10 rounded-lg bg-pm-elevated flex items-center justify-center"
                        >
                            <svg
                                class="h-5 w-5 text-pm-muted"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                    <span class="text-xs text-pm-muted group-hover:text-pm-gold transition-colors mt-2 block">Ver →</span>
                </button>

                <button
                    onclick="filterAppointments('PENDING')"
                    class="bg-pm-surface border border-pm-border rounded-xl p-5 w-full text-left hover:border-pm-gold transition-colors group cursor-pointer"
                >
                    <div class="flex items-center justify-between">
                        <div>
                            <p
                                class="text-xs font-medium text-pm-dim uppercase tracking-wider"
                            >
                                Por Confirmar
                            </p>
                            <p
                                class="text-2xl font-bold text-yellow-400 mt-1"
                                id="pending-appointments"
                            >
                                —
                            </p>
                        </div>
                        <div
                            class="h-10 w-10 rounded-lg bg-yellow-400/10 flex items-center justify-center"
                        >
                            <svg
                                class="h-5 w-5 text-yellow-400"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                    <span class="text-xs text-pm-muted group-hover:text-pm-gold transition-colors mt-2 block">Ver →</span>
                </button>

                <button
                    onclick="filterAppointments('CONFIRMED')"
                    class="bg-pm-surface border border-pm-border rounded-xl p-5 w-full text-left hover:border-pm-gold transition-colors group cursor-pointer"
                >
                    <div class="flex items-center justify-between">
                        <div>
                            <p
                                class="text-xs font-medium text-pm-dim uppercase tracking-wider"
                            >
                                Confirmadas
                            </p>
                            <p
                                class="text-2xl font-bold text-green-400 mt-1"
                                id="confirmed-appointments"
                            >
                                —
                            </p>
                        </div>
                        <div
                            class="h-10 w-10 rounded-lg bg-green-400/10 flex items-center justify-center"
                        >
                            <svg
                                class="h-5 w-5 text-green-400"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                    <span class="text-xs text-pm-muted group-hover:text-pm-gold transition-colors mt-2 block">Ver →</span>
                </button>

                <button
                    onclick="filterAppointments('COMPLETED')"
                    class="bg-pm-surface border border-pm-border rounded-xl p-5 w-full text-left hover:border-pm-gold transition-colors group cursor-pointer"
                >
                    <div class="flex items-center justify-between">
                        <div>
                            <p
                                class="text-xs font-medium text-pm-dim uppercase tracking-wider"
                            >
                                Completadas
                            </p>
                            <p
                                class="text-2xl font-bold text-blue-400 mt-1"
                                id="completed-appointments"
                            >
                                —
                            </p>
                        </div>
                        <div
                            class="h-10 w-10 rounded-lg bg-blue-400/10 flex items-center justify-center"
                        >
                            <svg
                                class="h-5 w-5 text-blue-400"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                    </div>
                    <span class="text-xs text-pm-muted group-hover:text-pm-gold transition-colors mt-2 block">Ver →</span>
                </button>
            </div>


            <!-- Day schedule grid -->
            <div class="mt-8">
                <DayScheduleGrid client:load />
            </div>

            <!-- Appointments List -->
            <div class="mt-8" id="appointments-section">
                <AppointmentList client:load />
            </div>
        </div>
    </main>
</Layout>

<script>
    import { appointmentService } from "../../../lib/api/appointments.ts";
    import { authService } from "../../../lib/api/auth.ts";

    declare global {
        interface Window {
            filterAppointments: (status: string) => void;
            confirmAllPending: () => Promise<void>;
        }
    }

    function toDateStr(d: Date) {
        return `${d.getFullYear()}-${(d.getMonth() + 1).toString().padStart(2, "0")}-${d.getDate().toString().padStart(2, "0")}`;
    }

    async function checkAuthAndRole() {
        if (!authService.isAuthenticated()) {
            window.location.href = "/login";
            return false;
        }
        const user = await authService.getProfile();
        if (!user) {
            window.location.href = "/login";
            return false;
        }
        if (user.role?.toUpperCase() === "CLIENT") {
            window.location.href = "/dashboard";
            return false;
        }
        return user;
    }

    async function loadProviderData() {
        try {
            const user = await checkAuthAndRole();
            if (!user) return;
            const isOwner = user.role?.toUpperCase() === "OWNER";

            const userName = user.email.split("@")[0];
            const capitalizedName =
                userName.charAt(0).toUpperCase() + userName.slice(1);

            const titleEl = document.getElementById("dashboard-title");
            if (titleEl)
                titleEl.textContent = isOwner
                    ? "Dashboard del Admin"
                    : "Dashboard del Proveedor";

            const providerInfoEl = document.getElementById("provider-info");
            if (providerInfoEl)
                providerInfoEl.textContent = isOwner
                    ? `${capitalizedName} · Admin`
                    : `${capitalizedName}`;

            if (isOwner) {
                document.getElementById("btn-team")?.classList.remove("hidden");
                document
                    .getElementById("btn-schedule")
                    ?.classList.remove("hidden");
                document
                    .getElementById("quick-team")
                    ?.classList.remove("hidden");
                document
                    .getElementById("quick-schedule")
                    ?.classList.remove("hidden");
            }

            let appointments: { status: string }[];
            if (isOwner) {
                appointments = await appointmentService.getBusinessAppointmentsAll();
            } else {
                const all = await appointmentService.getUserAppointments();
                appointments = all.filter((a) => a.status !== "CANCELLED");
            }

            document.getElementById("total-appointments")!.textContent =
                appointments.length.toString();
            document.getElementById("pending-appointments")!.textContent =
                appointments
                    .filter((a) => a.status === "PENDING")
                    .length.toString();
            document.getElementById("confirmed-appointments")!.textContent =
                appointments
                    .filter((a) => a.status === "CONFIRMED")
                    .length.toString();
            document.getElementById("completed-appointments")!.textContent =
                appointments
                    .filter((a) => a.status === "COMPLETED")
                    .length.toString();
        } catch (error) {
            console.error("Error loading provider data:", error);
        }
    }

    window.confirmAllPending = async function () {
        try {
            const user = await authService.getProfile();
            if (!user) return;
            const isOwner = user.role?.toUpperCase() === "OWNER";

            let appointments: { id: number; status: string }[];
            if (isOwner) {
                appointments = await appointmentService.getBusinessAppointmentsAll();
            } else {
                appointments = await appointmentService.getUserAppointments();
            }

            const pending = appointments.filter((a) => a.status === "PENDING");
            if (pending.length === 0) {
                alert("No hay citas pendientes para confirmar");
                return;
            }
            if (!confirm(`¿Confirmar ${pending.length} citas pendientes?`))
                return;
            for (const appointment of pending) {
                await appointmentService.updateAppointment(appointment.id, {
                    status: "CONFIRMED",
                });
            }
            alert(`${pending.length} citas confirmadas exitosamente`);
            location.reload();
        } catch (error) {
            console.error("Error confirming appointments:", error);
            alert("Error al confirmar las citas");
        }
    };

    window.filterAppointments = function (status: string) {
        window.dispatchEvent(
            new CustomEvent("filter-appointments", { detail: { status } }),
        );
        document
            .getElementById("appointments-section")
            ?.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    document.addEventListener("DOMContentLoaded", loadProviderData);
    window.addEventListener("appointment-updated", loadProviderData);
</script>
