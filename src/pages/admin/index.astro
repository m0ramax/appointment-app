---
import Layout from "../../layouts/Layout.astro";
import AdminPanel from "../../components/admin/AdminPanel";
---

<Layout title="Super Admin" description="Panel de administración de la plataforma">
  <main class="py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-400/10 text-red-400 border border-red-400/20 mb-3">
          Super Admin
        </div>
        <h1 class="text-2xl font-bold text-pm-text">Panel de Plataforma</h1>
        <p class="mt-1 text-sm text-pm-muted">Gestiona negocios e invitaciones</p>
      </div>

      <AdminPanel client:load />
    </div>
  </main>
</Layout>

<script>
  import { authService } from "../../lib/api/auth.ts";

  async function checkSuperAdmin() {
    if (!authService.isAuthenticated()) {
      window.location.href = "/login";
      return;
    }
    const user = await authService.getProfile();
    if (!user || user.role?.toUpperCase() !== "SUPER_ADMIN") {
      window.location.href = "/";
    }
  }

  document.addEventListener("DOMContentLoaded", checkSuperAdmin);
</script>
